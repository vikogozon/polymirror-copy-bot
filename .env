POLY_CLOB_HOST=https://clob.polymarket.com
DATA_TIMEOUT_SECONDS=5
DATABASE_PATH=data/copypoly.sqlite
POLL_SECONDS=0.25
TRADES_LIMIT=25
TRADE_TAKER_ONLY=false
INCLUDE_ACTIVITY=true
TRADE_LOOKBACK_SECONDS=300
START_AFTER_TIMESTAMP=0

COPY_BUYS=true
COPY_SELLS=true
BLOCK_OPPOSITE_BUYS=false
ALLOW_CHEAP_HEDGE_BUYS=false
HEDGE_MAX_PRICE=0.25
HEDGE_MAX_USDC=5
HEDGE_MAX_RATIO=0.25

SIZING_MODE=fixed_usdc
