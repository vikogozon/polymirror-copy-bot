POSITION_PERCENT=0.02
CAPITAL_USDC=200
COPY_RATIO=1.0
AUTO_CAPITAL_FROM_BALANCE=false
AUTO_CAPITAL_INCLUDE_OPEN_VALUE=false
SELL_SYNC_MODE=position_fraction
MIN_TRADE_USDC=0
MAX_TRADE_USDC=0
MAX_MARKET_USDC=0
MAX_MARKET_BUYS=0
MAX_TOTAL_OPEN_USDC=0
MAX_OPEN_POSITIONS=0
MARKET_COOLDOWN_SECONDS=60
DAILY_MAX_USDC=0
MIN_PRICE=0.001
MAX_PRICE=0.999
SLIPPAGE_BPS=100
TICK_SIZE=0.01

ALLOW_LIVE_SELLS=true
ENFORCE_LIVE_PRICE_PROTECTION=false
LIVE_ORDER_MODE=market
LIVE_ORDER_TYPE=FAK
LIVE_RECONCILE_ATTEMPTS=5
LIVE_RECONCILE_SLEEP_SECONDS=1

REAL_TRADING_CONFIRM=YES_I_ACCEPT_REAL_TRADING_RISK

